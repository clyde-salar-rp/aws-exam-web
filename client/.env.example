# ==============================================
# AWS Exam Prep - Client Environment Variables
# ==============================================

# ----------------------------------------------
# API Configuration
# ----------------------------------------------
# For Development: Point to local server
# VITE_API_URL=http://localhost:5000
#
# For Production (Vercel): Leave blank to use same origin
# VITE_API_URL=
#
# Vercel automatically serves the API from /api routes
# No need to specify URL when frontend and API are on same domain

VITE_API_URL=http://localhost:5000
